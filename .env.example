# ─────────────────────────────────────────────────────────────────────────────
# Ledger System — Environment Variables
#
# 1. Copy this file:   cp .env.example .env
# 2. Replace every REPLACE_ placeholder with real values.
# 3. Never commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# When running via Docker Compose the host is the service name 'db'.
# For local development against a native Postgres use 'localhost'.
DB_NAME=REPLACE_DB_NAME
DB_USER=REPLACE_DB_USER
# Generate a strong password: openssl rand -base64 24
DB_PASSWORD=REPLACE_DB_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret must be ≥ 32 characters.  Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_JWT_SECRET
JWT_ISSUER=REPLACE_JWT_ISSUER
JWT_AUDIENCE=REPLACE_JWT_AUDIENCE
# Token lifetimes (defaults shown)
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Angular frontend.
# Example: http://localhost:4200
CORS_ORIGIN=REPLACE_CORS_ORIGIN

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PERMIT=100
RATE_LIMIT_WINDOW=60

# ── Seed data ─────────────────────────────────────────────────────────────────
# The seeder creates this admin account on first run (--seed flag).
ADMIN_EMAIL=REPLACE_ADMIN_EMAIL
ADMIN_PASSWORD=REPLACE_ADMIN_PASSWORD

# ── API server ────────────────────────────────────────────────────────────────
# Host port that maps to container port 8080
API_PORT=8080

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
# Options: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development
