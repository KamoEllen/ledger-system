# ─────────────────────────────────────────────────────────────────
# Ledger System — Environment Variables
# Copy this file to .env and replace all REPLACE_ values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Host: use 'db' when running via Docker Compose, 'localhost' for local dev
DB_HOST=REPLACE_DB_HOST
DB_PORT=5432
DB_NAME=REPLACE_DB_NAME
DB_USER=REPLACE_DB_USER
# Use a strong random password in all environments
DB_PASSWORD=REPLACE_DB_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────
# Secret must be at least 32 characters. Generate with:
# openssl rand -base64 48
JWT_SECRET=REPLACE_JWT_SECRET
JWT_ISSUER=REPLACE_JWT_ISSUER
JWT_AUDIENCE=REPLACE_JWT_AUDIENCE

# ── Seed data ─────────────────────────────────────────────────────
ADMIN_EMAIL=REPLACE_ADMIN_EMAIL
ADMIN_PASSWORD=REPLACE_ADMIN_PASSWORD

# ── ASP.NET Core ──────────────────────────────────────────────────
# Options: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development
